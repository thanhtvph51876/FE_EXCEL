# =============================================================================
# ExcelAI Backend — Environment Configuration
# Copy file này thành .env và điền giá trị thực
# =============================================================================

# ── Môi trường ──────────────────────────────────────────────────────────────
# "production" | "development"
# production: tắt Swagger UI, tắt CORS wildcard, bắt buộc CORS_ORIGINS
ENVIRONMENT=production

# ── Database ─────────────────────────────────────────────────────────────────
# Dùng DATABASE_URL nếu có (ưu tiên hơn từng biến riêng)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

DB_HOST=localhost
DB_PORT=5432
DB_NAME=excelai
DB_USER=postgres
DB_PASSWORD=your_password

# Pool: server nhỏ (1-2GB RAM) → MIN=2 MAX=20
#       server vừa (4GB+)       → MIN=5 MAX=50
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── Bảo mật ──────────────────────────────────────────────────────────────────
# Tạo bằng: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_64_char_random_hex_generated_by_command_above

ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=30
ACCOUNT_LOCK_MINUTES=15

# ── CORS — BẮT BUỘC trong production ────────────────────────────────────────
# Điền domain thực của frontend, không dùng wildcard
CORS_ORIGINS=https://your-domain.com

# Nếu có CDN hoặc nhiều domain, thêm dấu phẩy:
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ── AI (Gemini) ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_REQUEST_TIMEOUT_SECONDS=120
GEMINI_JSON_TIMEOUT_SECONDS=120
GEMINI_STREAM_CHUNK_TIMEOUT_SECONDS=60
GEMINI_MAX_ATTEMPTS=2

# Số AI request đồng thời tối đa
# Server nhỏ (1-2GB RAM): 5-8
# Server vừa (4GB+):      10-16
GEMINI_MAX_CONCURRENCY=8

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-domain.com
APP_BASE_URL=https://your-domain.com
WEBHOOK_BASE_URL=https://api.your-domain.com

# ── Lưu trữ file ──────────────────────────────────────────────────────────────
# "local" hoặc "s3" (nếu dùng S3/R2/MinIO)
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=/var/data/excelai-storage
STORAGE_BUCKET=excel-files

# S3/R2 (bỏ trống nếu dùng local)
# STORAGE_REGION=ap-southeast-1
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_ENDPOINT_URL=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Email admin (nhiều email cách nhau dấu phẩy)
ADMIN_EMAILS=admin@your-domain.com

# ── Proxy (Nginx/Cloudflare) ──────────────────────────────────────────────────
# IP của reverse proxy để lấy đúng IP client từ X-Forwarded-For
# TRUSTED_PROXY_IPS=127.0.0.1

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ExcelAI

PASSWORD_RESET_MINUTES=30
# Không bao giờ bật true trong production!
EXPOSE_DEV_RESET_TOKEN=false

# ── Thanh toán ────────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=payos
# PAYMENT_PROVIDER=vnpay | momo | stripe | none

PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://pay.vnpay.vn/vpcpay.html
VNPAY_RETURN_URL=
VNPAY_IPN_URL=

MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=
MOMO_IPN_URL=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

GOOGLE_CLIENT_ID=
